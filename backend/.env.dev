# =========================
# App
# =========================
APP_ENV=development
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000

# =========================
# Database
# =========================
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/render_factory

# =========================
# Celery / Redis
# =========================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true

# =========================
# Local storage
# =========================
STORAGE_ROOT=/app/storage
RENDER_CACHE_DIR=/app/storage/render_cache
RENDER_OUTPUT_DIR=/app/storage/render_outputs

# =========================
# Object storage / MinIO / S3
# =========================
OBJECT_STORAGE_PROVIDER=minio
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=render-assets
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=http://localhost:9000/render-assets
SIGNED_URL_EXPIRES_SECONDS=3600

# =========================
# Google / Veo
# =========================
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEX=true
GOOGLE_APPLICATION_CREDENTIALS=
VEO_DEFAULT_MODEL=veo-3.1-generate-001
VEO_FAST_MODEL=veo-3.1-fast-generate-001
VEO_OUTPUT_GCS_URI=

# =========================
# Runway
# =========================
RUNWAYML_API_SECRET=
RUNWAY_API_BASE_URL=https://api.dev.runwayml.com
RUNWAY_API_VERSION=2024-11-06
RUNWAY_DEFAULT_MODEL=gen4.5

# =========================
# Kling
# =========================
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE_URL=https://api.klingai.com
KLING_DEFAULT_MODEL=kling-v1
KLING_TOKEN_TTL_SECONDS=1800

# =========================
# Provider HTTP tuning
# =========================
PROVIDER_HTTP_TIMEOUT_SECONDS=120