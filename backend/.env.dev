# =========================
# App
# =========================
APP_ENV=development
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000

# =========================
# Database
# =========================
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/render_factory

# =========================
# Celery / Redis
# =========================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Celery tuning
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true

# =========================
# Local storage
# =========================
STORAGE_ROOT=/app/storage
RENDER_CACHE_DIR=/app/storage/render_cache
RENDER_OUTPUT_DIR=/app/storage/render_outputs

# =========================
# Object storage / MinIO / S3
# =========================
OBJECT_STORAGE_PROVIDER=minio

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=render-assets
S3_REGION=us-east-1

# Public URL for local dev preview
S3_PUBLIC_BASE_URL=http://localhost:9000/render-assets

# Signed URL expiry
SIGNED_URL_EXPIRES_SECONDS=3600

# =========================
# Google / Veo
# =========================
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEX=true
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_API_KEY=
VEO_DEFAULT_MODEL=veo-3.1-generate-001
VEO_FAST_MODEL=veo-3.1-fast-generate-001
VEO_OUTPUT_GCS_URI=

# =========================
# Runway
# =========================
RUNWAYML_API_SECRET=
RUNWAY_API_BASE_URL=https://api.dev.runwayml.com
RUNWAY_API_VERSION=2024-11-06
RUNWAY_DEFAULT_MODEL=gen4.5

# =========================
# Kling
# =========================
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE_URL=https://api.klingai.com
KLING_DEFAULT_MODEL=kling-v1
KLING_TOKEN_TTL_SECONDS=1800

# =========================
# Provider HTTP tuning
# =========================
PROVIDER_HTTP_TIMEOUT_SECONDS=120
PROVIDER_CALLBACK_USE_RELAY=false
PROVIDER_CALLBACK_PUBLIC_BASE_URL=
PROVIDER_CALLBACK_RELAY_PATH_TEMPLATE=/hooks/{provider}

PROVIDER_MAX_RETRIES=2
PROVIDER_RETRY_BASE_SECONDS=2
PROVIDER_ALLOW_MOCK_FALLBACK=true
PROVIDER_CALLBACK_SHARED_SECRET=
RUNWAY_CALLBACK_SHARED_SECRET=
KLING_CALLBACK_SHARED_SECRET=
PROVIDER_RELAY_SHARED_SECRET=replace-me
RUNWAY_RELAY_SHARED_SECRET=
KLING_RELAY_SHARED_SECRET=
VEO_RELAY_SHARED_SECRET=
PROVIDER_INGRESS_SIGNATURE_TTL_SECONDS=300
KLING_API_TOKEN=
KLING_TEXT_TO_VIDEO_PATH=/v1/videos/text2video
KLING_TEXT_TO_VIDEO_STATUS_PATH_TEMPLATE=/v1/videos/text2video/{task_id}

DECISION_ENGINE_ENABLED=true
DECISION_ENGINE_POLICY_PATH=

CONTROL_PLANE_ENABLED=true
DEFAULT_DISPATCH_BATCH_LIMIT=10
DEFAULT_POLL_COUNTDOWN_SECONDS=60

AUTOPILOT_CONTROL_FABRIC_ENABLED=true

OBSERVABILITY_ENABLED=true
NOTIFICATION_PLANE_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

AUDIO_UPLOAD_DIR=/app/storage/audio_uploads
AUDIO_OUTPUT_DIR=/app/storage/audio_outputs
AUDIO_OUTPUT_FORMAT=mp3_44100_128
AUDIO_UPLOAD_TO_OBJECT_STORAGE=true
FFMPEG_BINARY=ffmpeg
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
DEFAULT_MUSIC_DURATION_SECONDS=30
FFPROBE_BINARY=ffprobe
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_TTS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_DEFAULT_STABILITY=0.45
ELEVENLABS_DEFAULT_SIMILARITY_BOOST=0.8
ELEVENLABS_ENABLE_MUSIC=false
DEFAULT_BREATH_PRESET=natural
DEFAULT_MUSIC_DUCKING_DB=10
DEFAULT_NARRATION_GAIN_DB=0
DEFAULT_MUSIC_GAIN_DB=-18
REQUIRE_VOICE_CONSENT=true
VOICE_CONSENT_MIN_CHARS=20
TEMPLATE_FACTORY_ENABLED=true
TEMPLATE_AUTO_EXTRACT_DRAFT=true
TEMPLATE_AUTO_APPLY_ENABLED=false
TEMPLATE_SAFE_AUTO_APPLY=false
VEO_REFERENCE_PREVIEW_MODEL=veo-3.1-generate-preview
VEO_ENABLE_REFERENCE_PREVIEW=false
VEO_ENABLE_SOUND_GENERATION=false
VEO_BATCH_MAX_SCRIPTS=100
